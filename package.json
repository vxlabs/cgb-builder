{
  "name": "cgb-builder",
  "version": "1.1.0",
  "description": "Automated polyglot code graph builder for AI-ready context bundles",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cgb": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "code-graph",
    "static-analysis",
    "tree-sitter",
    "ai-context",
    "dependency-graph",
    "mcp",
    "model-context-protocol",
    "polyglot",
    "cgb"
  ],
  "author": "VxLabs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vxlabs/cgb-builder.git"
  },
  "homepage": "https://github.com/vxlabs/cgb-builder#readme",
  "bugs": {
    "url": "https://github.com/vxlabs/cgb-builder/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "glob": "^10.3.12",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "sql.js": "^1.12.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.20.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
